# Google Gemini API (primary image generation backend)
GEMINI_API_KEY=

# Pipeline API (FastAPI backend URL, used by Next.js proxy)
PIPELINE_API_URL=http://localhost:8000

# Pipeline API auth (shared secret for mutation endpoints)
PIPELINE_API_SECRET=

# CORS allowed origins (comma-separated, used by FastAPI)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Next.js public vars
NEXT_PUBLIC_PIPELINE_API_URL=http://localhost:8000
